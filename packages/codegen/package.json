{
  "name": "@repo/codegen",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run build.ts",
    "start": "bun run build > /dev/null && bun pkg/dist/cli/main.js",
    "check:types": "bun run --bun tsc",
    "test": "bun test",
    "generate:self": "bun start generate --commands src/cli/commands --out src/cli/commandTree.gen.ts --core-module @repo/core",
    "generate:fixtures": "bun start generate --commands test/fixtures/basic/commands --out test/fixtures/basic/commandTree.expected.ts --core-module @repo/core"
  },
  "bin": {
    "parsh-codegen": "./src/cli/bin.ts"
  },
  "devDependencies": {
    "@repo/core": "workspace:*",
    "@repo/pack-utils": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "zod": "catalog:"
  },
  "dependencies": {
    "typescript": "catalog:"
  },
  "imports": {
    "#*": "./src/*"
  }
}
