{
  "name": "@repo/examples-awslike",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run build.ts",
    "start": "bun run build > /dev/null && bun dist/main.js",
    "check:types": "bun run --bun tsc",
    "generate": "parsh-codegen generate --commands src/commands --out src/commandTree.gen.ts --core-module @repo/core"
  },
  "dependencies": {
    "@repo/core": "workspace:*",
    "@repo/env": "workspace:*",
    "@repo/files": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repo/codegen": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "typescript": "catalog:"
  }
}
